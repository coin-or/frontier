# Anthropic API key — required. Reads ANTHROPIC_API_KEY or falls back to CLAUDE_API_KEY.
# Recommended: keep in your shell env (~/.zshenv or ~/.config/zsh/secrets), not in .env files.
# ANTHROPIC_API_KEY=sk-ant-...

# Frontier MCP server URL — defaults to live deployment
FRONTIER_MCP_URL=https://frontier-592q.onrender.com/sse

# Anthropic model to use (default: claude-opus-4-7)
ANTHROPIC_MODEL=claude-opus-4-7

# Pluggable agent runtime: messages-api (default) | managed-agents | agent-sdk
AGENT_BACKEND=messages-api
