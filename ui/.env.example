# ─── Frontier MCP engine ────────────────────────────────────────────────────
# Where the engine lives. Default (both unset) is a local engine at
# http://localhost:8000/sse. In production set FRONTIER_MCP_HOST (Render wires
# this from the engine service) and the app composes https://$FRONTIER_MCP_HOST/sse.
# FRONTIER_MCP_URL=http://localhost:8000/sse
# FRONTIER_MCP_HOST=frontier-xxxx.onrender.com
# Shared bearer token gating a hosted engine (must match the engine's value).
# Leave unset for a local/ungated engine.
# FRONTIER_MCP_TOKEN=

# ─── Web UI access gate (HTTP Basic Auth) ───────────────────────────────────
# Shared password gating the hosted web UI — covers the page AND /api/chat. Hand
# it to beta users. UNSET = open (local dev / self-host). Set it in production,
# or anyone with the URL can use the app and spend your ANTHROPIC_API_KEY. This
# is separate from FRONTIER_MCP_TOKEN (which gates the engine, not the UI).
# Username is optional — unset = any username + the password below.
# UI_ACCESS_USER=frontier
# UI_ACCESS_PASSWORD=

# ─── Pluggable agent runtime ────────────────────────────────────────────────
# Selects which backend translates between the chat UI and a model.
#   messages-api      — Anthropic Messages API + server-side MCP connector
#                       (requires https:// MCP URL — Anthropic calls it from
#                       their infra, not from this service)
#   anthropic-local   — Anthropic Messages API + client-side MCP loop
#                       (works with localhost MCP, extended thinking enabled)
#   openai-compatible — Any provider speaking OpenAI Chat Completions +
#                       client-side MCP loop (point OPENAI_BASE_URL anywhere)
# This template is set for LOCAL dev: anthropic-local runs the agent loop in
# this app and talks to a local engine directly (no public URL or token needed).
# Production (see ../render.yaml) uses messages-api against the hosted engine.
AGENT_BACKEND=anthropic-local

# ─── Anthropic config (used by messages-api and anthropic-local) ────────────
# Recommended: keep keys in your shell env (~/.zshenv), not in .env files.
# ANTHROPIC_API_KEY=sk-ant-...   # falls back to CLAUDE_API_KEY if unset
ANTHROPIC_MODEL=claude-opus-4-8
# Adaptive thinking effort (messages-api and anthropic-local, Opus 4.7/4.8):
# low | medium | high | xhigh | max (default: high)
# ANTHROPIC_EFFORT=high
# ANTHROPIC_MAX_TOKENS=32000

# ─── OpenAI-compatible config (used by openai-compatible backend) ───────────
# Works with any provider whose chat-completions API matches OpenAI's wire
# format. Point OPENAI_BASE_URL / OPENAI_MODEL at the provider you want — one
# adapter, any provider, no code changes.
OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# Optional — only forwarded to providers that accept the field:
# OPENAI_REASONING_EFFORT=high
#
# Worked example — NVIDIA NIM (build.nvidia.com). NIM serves open models over
# the same Chat-Completions wire format, so it drops straight into this backend.
# Get an nvapi-... key from build.nvidia.com, then:
#   AGENT_BACKEND=openai-compatible
#   OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
#   OPENAI_API_KEY=nvapi-...
#   OPENAI_MODEL=nvidia/nemotron-3-super-120b-a12b
# Nemotron 3 is a reasoning model: NIM returns its chain-of-thought in a
# separate `reasoning_content` field that this adapter ignores, so only the
# final answer reaches the chat — matching the UI's clean, chart-first output.
