{
  "name": "ETF Portfolio",
  "domain": "investment",
  "context": "Allocate across a 30-ETF universe to balance return, volatility (via covariance), and yield. Options, scores, and the covariance interaction matrix are in scores.json.",
  "approach": "proportional",
  "objectives": [
    {
      "name": "Return",
      "direction": "maximize",
      "unit": "%",
      "aggregation": "avg"
    },
    {
      "name": "Volatility",
      "direction": "minimize",
      "unit": "%",
      "aggregation": "quadratic"
    },
    {
      "name": "Yield",
      "direction": "maximize",
      "unit": "%",
      "aggregation": "avg"
    }
  ],
  "constraints": [
    {
      "type": "max_allocation",
      "max": 30
    },
    {
      "type": "objective_bound",
      "objective": "Volatility",
      "operator": "max",
      "value": 20.0
    },
    {
      "type": "group_limit",
      "options": [
        "VOO",
        "VUG",
        "VTV",
        "VO",
        "VB",
        "SCHD"
      ],
      "min": 0,
      "max": 3
    },
    {
      "type": "group_limit",
      "options": [
        "VEA",
        "VWO",
        "VGK",
        "EWJ",
        "MCHI"
      ],
      "min": 0,
      "max": 3
    },
    {
      "type": "group_limit",
      "options": [
        "BND",
        "VGSH",
        "VGLT",
        "TIP",
        "HYG",
        "EMB"
      ],
      "min": 0,
      "max": 3
    },
    {
      "type": "group_limit",
      "options": [
        "VGT",
        "VHT",
        "VDE",
        "VFH",
        "VPU",
        "VDC",
        "VOX"
      ],
      "min": 0,
      "max": 3
    },
    {
      "type": "group_limit",
      "options": [
        "VNQ",
        "VNQI",
        "GLD",
        "GSG",
        "DBA",
        "IGF"
      ],
      "min": 0,
      "max": 3
    }
  ],
  "scenarios": [
    {
      "name": "rate_cuts",
      "probability": null,
      "description": "Lower rates compress yields across the book (illustrative).",
      "motivated_by": "",
      "score_overrides": [],
      "score_adjustments": [
        {
          "objective": "Yield",
          "multiply": 0.85,
          "add": null
        }
      ],
      "constraint_overrides": [],
      "interaction_matrix_overrides": []
    },
    {
      "name": "recession",
      "probability": null,
      "description": "US-equity correlations rise ~50% (regime shift via scale_groups).",
      "motivated_by": "",
      "score_overrides": [],
      "score_adjustments": [],
      "constraint_overrides": [],
      "interaction_matrix_overrides": [
        {
          "objective": "Volatility",
          "entries": {},
          "mode": "upsert",
          "scale_groups": [
            {
              "options": [
                "VOO",
                "VUG",
                "VTV",
                "VO",
                "VB",
                "SCHD"
              ],
              "factor": 1.5
            }
          ]
        }
      ]
    },
    {
      "name": "inflation",
      "probability": null,
      "description": "High inflation: rates rise (yields up) while real returns are eroded.",
      "motivated_by": "",
      "score_overrides": [],
      "score_adjustments": [
        {
          "objective": "Return",
          "multiply": 0.9,
          "add": null
        },
        {
          "objective": "Yield",
          "multiply": 1.15,
          "add": null
        }
      ],
      "constraint_overrides": [],
      "interaction_matrix_overrides": []
    }
  ]
}