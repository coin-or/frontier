{
  "name": "Scarce Supply Rationing",
  "domain": "semiconductor supply allocation",
  "context": "One quarter's constrained memory-chip supply, split across 36 customers whose committed demand runs ~1.8x what the fabs will deliver \u2014 every plan cuts someone. Distributors pay spot prices; hyperscale and tier-1 contracts pay less but carry the strategic relationships (and contractual minimum shares) the board protects. The question is not who to serve \u2014 it's what protecting each account costs, and who absorbs the cut when a fab outage shrinks supply under the same commitments.",
  "approach": "proportional",
  "objectives": [
    {
      "name": "Revenue",
      "direction": "maximize",
      "unit": "$M",
      "aggregation": "sum"
    },
    {
      "name": "StrategicValue",
      "direction": "maximize",
      "unit": "score",
      "aggregation": "sum"
    },
    {
      "name": "DemandFragility",
