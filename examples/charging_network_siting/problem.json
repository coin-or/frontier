{
  "name": "Charging Network Siting",
  "domain": "EV infrastructure planning",
  "context": "A charging operator picks which of 72 candidate fast-charging sites to build across seven metros and three highway corridors. Linear reach numbers overstate coverage where catchments overlap \u2014 two downtown garages share the same drivers \u2014 so an overlap interaction matrix carries the correction (pairwise approximation). A public commitment says every metro gets at least one site; a $34M budget, per-metro interconnection-queue caps, competing-lot exclusions, and a committed corridor flagship do the rest.",
  "approach": "binary",
  "objectives": [
    {
      "name": "DriversServed",
      "direction": "maximize",
      "unit": "k-drivers/day",
      "aggregation": "sum"
    },
    {
      "name": "Overlap",
      "direction": "minimize",
      "unit": "score",
      "aggregation": "quadratic"
    },
    {
      "name": "Cost",
