{
  "name": "Research Cohort Selection",
  "domain": "clinical research operations",
  "context": "A research team picks exactly 12 of 60 screened volunteers for a biomarker study. Signal strength, retention risk, and per-participant cost pull apart by construction: the highest-expression volunteers screen at the expensive academic centers and carry the most dropout risk. Stratum floors (the cohort must span all four profiles) and per-site caps (no site may dominate) force the spread a top-12-by-signal list ignores.",
  "approach": "binary",
  "objectives": [
    {
      "name": "SignalStrength",
      "direction": "maximize",
      "unit": "score",
      "aggregation": "sum"
    },
    {
      "name": "RetentionRisk",
      "direction": "minimize",
      "unit": "score",
      "aggregation": "sum"
    },
    {
      "name": "CostPerParticipant",
      "direction": "minimize",
      "unit": "$k",
      "aggregation": "sum"
    }
  ],
  "constraints": [
