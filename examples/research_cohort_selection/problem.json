  "objectives": [
    {
      "name": "SignalStrength",
      "direction": "maximize",
      "unit": "score",
      "aggregation": "sum"
    },
    {
      "name": "RetentionRisk",
      "direction": "minimize",
      "unit": "score",
      "aggregation": "sum"
    },
    {
      "name": "CostPerParticipant",
      "direction": "minimize",
      "unit": "$k",
      "aggregation": "sum"
    }
  ],
