{
  "name": "Production Mix Allocation",
  "domain": "manufacturing",
  "context": "Allocate a fixed plant capacity across products on three lines to maximize unit margin, throughput, and sustainability. No single product may take more than 30% of capacity, and each line can run at most two SKUs at once (a changeover/tooling limit). Three purely linear objectives over a continuous allocation make this an exact multi-objective LP, so the solver returns exact duals beyond the frontier: which constraint is the binding lever (shadow price), which product is the closest near-miss (reduced cost), and which SKU is the fractional swing that sets the marginal price. Two scenarios stress the mix.",
  "approach": "proportional",
  "objectives": [
    {
      "name": "Margin",
      "direction": "maximize",
      "unit": "$/unit",
      "aggregation": "avg"
    },
    {
      "name": "Throughput",
      "direction": "maximize",
      "unit": "k units/wk",
      "aggregation": "avg"
    },
    {
      "name": "Sustainability",
      "direction": "maximize",
      "unit": "score",
      "aggregation": "avg"
    }
  ],
  "constraints": [
    {
      "type": "max_allocation",
      "max": 30
    },
    {
      "type": "group_limit",
      "options": [
        "Aerospace Fittings",
        "Medical Components",
        "Optics Housings"
      ],
      "min": 0,
      "max": 2
    },
    {
      "type": "group_limit",
      "options": [
        "Fasteners",
        "Brackets",
        "Connectors",
        "Stamped Housings"
      ],
      "min": 0,
      "max": 2
    },
    {
      "type": "group_limit",
      "options": [
        "Pump Assemblies",
        "Valve Bodies",
        "Gear Sets"
      ],
      "min": 0,
      "max": 2
    }
  ],
  "scenarios": [
    {
      "name": "input_cost_spike",
      "probability": null,
      "description": "A raw-material and energy cost spike squeezes the thin-margin commodity line; the differentiated Precision and Standard products hold their pricing.",
      "motivated_by": "",
      "score_overrides": [
