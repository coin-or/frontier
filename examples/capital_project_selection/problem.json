{
  "name": "Capital Project Selection",
  "domain": "corporate finance",
  "context": "Choose which of 24 capital projects to fund this cycle to maximize NPV and strategic fit while holding down spend and portfolio risk. Bigger bets cost more and carry more risk; compliance work is low-NPV but mandatory; some projects depend on enabling infrastructure and some vendors are mutually exclusive. Hard budget of $140M. Genuinely conflicting; needs an exact selection, not a spreadsheet ranking.",
  "approach": "binary",
  "objectives": [
    {
      "name": "NPV",
      "direction": "maximize",
      "unit": "$M",
      "aggregation": "sum"
    },
    {
      "name": "Cost",
      "direction": "minimize",
      "unit": "$M",
      "aggregation": "sum"
    },
    {
      "name": "Risk",
      "direction": "minimize",
      "unit": "score",
      "aggregation": "sum"
    },
    {
      "name": "StrategicFit",
      "direction": "maximize",
      "unit": "score",
      "aggregation": "sum"
    }
  ],
  "constraints": [
    {
      "type": "objective_bound",
      "objective": "Cost",
      "operator": "max",
      "value": 140.0
    },
    {
      "type": "cardinality",
      "min": 6,
      "max": 14
    },
    {
      "type": "force_include",
      "option": "P19"
    },
    {
      "type": "dependency",
      "if_option": "P07",
      "then_option": "P22"
    },
    {
      "type": "dependency",
      "if_option": "P08",
      "then_option": "P22"
    },
    {
      "type": "exclusion_pair",
      "option_a": "P01",
      "option_b": "P02"
    },
    {
      "type": "exclusion_pair",
      "option_a": "P11",
      "option_b": "P12"
    }
  ],
  "scenarios": [
    {
      "name": "budget_cut",
      "description": "Capex tightened to $100M mid-cycle.",
      "constraint_overrides": [
        {
          "type": "objective_bound",
          "objective": "Cost",
          "operator": "max",
          "value": 100.0
        },
        {
          "type": "cardinality",
          "min": 5,
          "max": 12
        },
        {
          "type": "force_include",
          "option": "P19"
        },
        {
          "type": "dependency",
          "if_option": "P07",
          "then_option": "P22"
        },
        {
          "type": "exclusion_pair",
          "option_a": "P01",
          "option_b": "P02"
        }
      ]
    },
    {
      "name": "compliance_wave",
      "description": "New regulation forces all compliance projects in.",
      "constraint_overrides": [
        {
          "type": "objective_bound",
          "objective": "Cost",
          "operator": "max",
          "value": 140.0
        },
        {
          "type": "cardinality",
          "min": 6,
          "max": 14
        },
        {
          "type": "force_include",
          "option": "P19"
        },
        {
          "type": "force_include",
          "option": "P20"
        },
        {
          "type": "force_include",
          "option": "P21"
        }
      ]
    }
  ]
}