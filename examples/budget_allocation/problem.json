{
  "name": "Growth Budget Allocation",
  "domain": "product",
  "context": "Split a fixed growth budget across 24 candidate initiatives from five departments, trading projected ROI against strategic reach and time-to-impact. No initiative above 20% of the budget, at most 3 funded per department, and the blended time-to-impact held within 9 months. Three purely linear objectives over a continuous allocation make this an exact multi-objective LP - beyond the frontier, the solver returns exact duals: which initiative is a near-miss (reduced cost) and which limit is binding (shadow price). A downturn scenario haircuts the discretionary growth bets.",
  "approach": "proportional",
  "objectives": [
    {
      "name": "ROI",
      "direction": "maximize",
      "unit": "%",
      "aggregation": "avg"
    },
    {
      "name": "Strategic Reach",
      "direction": "maximize",
      "unit": "score",
      "aggregation": "avg"
    },
    {
      "name": "TimeToImpact",
      "direction": "minimize",
      "unit": "months",
      "aggregation": "avg"
    }
  ],
  "constraints": [
    {
      "type": "max_allocation",
      "max": 20
    },
    {
      "type": "objective_bound",
      "objective": "TimeToImpact",
      "operator": "max",
      "value": 9.0
    },
    {
      "type": "group_limit",
      "options": [
        "AI Copilot",
        "Self-Serve Onboarding",
        "Mobile Revamp",
        "Marketplace",
        "Usage-Based Pricing",
        "Accessibility Overhaul"
      ],
      "min": 0,
      "max": 3
    },
    {
      "type": "group_limit",
      "options": [
        "Data Platform",
        "Enterprise SSO",
        "API Gateway Rebuild",
        "Observability Stack",
        "Multi-Region Failover"
      ],
      "min": 0,
      "max": 3
    },
    {
      "type": "group_limit",
      "options": [
        "Localization",
        "Brand Refresh",
        "Lifecycle Campaigns",
        "SEO Content Engine",
        "Community Program"
      ],
      "min": 0,
      "max": 3
    },
    {
      "type": "group_limit",
      "options": [
        "Partner API",
        "Reseller Channel",
        "Tech Alliances",
        "Integration Marketplace"
      ],
      "min": 0,
      "max": 3
    },
    {
      "type": "group_limit",
      "options": [
        "Sales Enablement",
        "Solutions Engineering",
        "Developer Relations",
        "Customer Education"
      ],
      "min": 0,
      "max": 3
    }
  ],
  "scenarios": [
