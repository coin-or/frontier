{
  "name": "Marketing Channel Budget",
  "domain": "marketing",
  "context": "Split a media budget across 40 channel x audience/geo cells balancing Conversions, Reach, ROAS, and Brand Lift. Direct-response cells convert and return well but reach few people; upper-funnel cells reach and build brand but convert poorly - and same-audience cells overlap, so blended reach combines sub-additively through the interaction matrix (sqrt of the quadratic form: stacking one audience saturates). The quadratic sits on a maximize objective, outside the mean-variance exact shape, so this decision runs on the approximate frontier end to end - the deliberate approx-first showcase.",
  "approach": "proportional",
  "objectives": [
    {
      "name": "Conversions",
      "direction": "maximize",
      "unit": "conv/$k",
      "aggregation": "avg"
    },
    {
      "name": "Reach",
      "direction": "maximize",
      "unit": "k impressions/$k",
      "aggregation": "quadratic"
    },
    {
      "name": "ROAS",
      "direction": "maximize",
      "unit": "x",
      "aggregation": "avg"
    },
    {
      "name": "BrandLift",
      "direction": "maximize",
      "unit": "score",
      "aggregation": "avg"
    }
  ],
  "constraints": [
    {
      "type": "max_allocation",
      "max": 15
    },
    {
      "type": "objective_bound",
      "objective": "ROAS",
      "operator": "min",
      "value": 2.0
    },
    {
      "type": "group_limit",
      "options": [
        "Search-US",
        "Search-EU",
        "Search-APAC",
        "Search-Brand-Defense"
      ],
      "min": 0,
      "max": 2
    },
    {
