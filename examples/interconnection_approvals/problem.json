{
  "name": "Interconnection Approvals",
  "domain": "grid planning",
  "context": "A regional grid operator decides which of 42 large-load interconnection requests to approve this cycle, alongside 16 enabling substation upgrades. Upgrades have zero standalone value \u2014 they pay only through the requests they unlock \u2014 and several requests share one enabler, one upgrade is the staged second phase of another, and the worth of an upgrade depends on the whole approval set. Four capex levels ($320M / $400M / $480M / $560M) are modeled as scenarios: the question is not just which portfolio, but which approvals survive every budget and what each next $80M actually buys.",
  "approach": "binary",
  "objectives": [
    {
      "name": "NetValue",
      "direction": "maximize",
      "unit": "$M",
      "aggregation": "sum"
    },
    {
      "name": "Cost",
      "direction": "minimize",
      "unit": "$M",
      "aggregation": "sum"
    },
    {
      "name": "ReliabilityRisk",
      "direction": "minimize",
      "unit": "score",
      "aggregation": "sum"
    }
  ],
