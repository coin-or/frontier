{
  "name": "Interconnection Approvals",
  "domain": "grid planning",
  "context": "A regional grid operator decides which of 22 large-load interconnection requests to approve this cycle, alongside 8 enabling substation upgrades. Upgrades have zero standalone value \u2014 they pay only through the requests they unlock \u2014 and several requests share one enabler, so the worth of an upgrade depends on the whole approval set. Three capex levels ($180M / $240M / $300M) are modeled as scenarios: the question is not just which portfolio, but which approvals survive every budget and what the next $60M actually buys.",
  "approach": "binary",
  "objectives": [
    {
      "name": "NetValue",
      "direction": "maximize",
      "unit": "$M",
      "aggregation": "sum"
    },
    {
      "name": "Cost",
      "direction": "minimize",
      "unit": "$M",
      "aggregation": "sum"
    },
    {
      "name": "ReliabilityRisk",
      "direction": "minimize",
      "unit": "score",
      "aggregation": "sum"
    }
  ],
