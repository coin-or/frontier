{
  "name": "Supplier Selection",
  "domain": "procurement",
  "context": "Allocate order share across 25 suppliers in 6 regions to balance unit cost, reliability, lead time, ESG risk, and correlated regional concentration risk. Cheaper suppliers tend to be less reliable, slower, and higher ESG/concentration risk \u2014 genuinely conflicting. No supplier over 15%, \u22643 active suppliers per region, and a weighted reliability floor. Options, scores, and the ConcentrationRisk interaction matrix are in scores.json.",
  "approach": "proportional",
  "objectives": [
    {
      "name": "Cost",
      "direction": "minimize",
      "unit": "$/unit",
      "aggregation": "avg"
    },
    {
      "name": "Reliability",
