{
  "name": "Supplier Selection",
  "domain": "procurement",
  "context": "Split a production order across 25 global suppliers balancing unit cost, reliability, lead time, ESG risk, and correlated regional concentration risk (quadratic, via the interaction matrix). Per-region active-supplier caps, a weighted reliability floor, and two contractual minimum shares - NA01 at 5% (strategic incumbent) and CN01 at 4% (legacy contract) - couple every share to every other. The mean-variance QP shape carries exact certification and solver duals: the reduced cost on a floored supplier prices what the contract costs, correlated risk included.",
  "approach": "proportional",
  "objectives": [
    {
      "name": "Cost",
      "direction": "minimize",
      "unit": "$/unit",
      "aggregation": "avg"
    },
    {
      "name": "Reliability",
      "direction": "maximize",
      "unit": "score",
      "aggregation": "avg"
    },
    {
      "name": "LeadTime",
      "direction": "minimize",
      "unit": "days",
      "aggregation": "avg"
    },
    {
      "name": "ESGRisk",
      "direction": "minimize",
      "unit": "score",
      "aggregation": "avg"
    },
    {
      "name": "ConcentrationRisk",
      "direction": "minimize",
      "unit": "score",
      "aggregation": "quadratic"
    }
  ],
  "constraints": [
    {
      "type": "max_allocation",
      "max": 15
    },
    {
      "type": "group_limit",
      "options": [
        "NA01",
        "NA02",
        "NA03",
        "NA04"
      ],
      "min": 0,
      "max": 3
